{
    "name": "@luka-cat-mimi/n8n-nodes-qingflow-oa",
    "version": "1.2.1",
    "description": "轻流OA N8N 集成插件",
    "keywords": [
        "n8n",
        "n8n-node",
        "n8n-community-node-package",
        "qingflow",
        "轻流",
        "OA"
    ],
    "license": "MIT",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "homepage": "https://github.com/luka-n8n-nodes/n8n-nodes-qingflow-oa#readme",
    "author": {
        "name": "luka-cat",
        "email": "luka.cat.mimi@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/luka-n8n-nodes/n8n-nodes-qingflow-oa.git"
    },
    "engines": {
        "node": ">=20.15"
    },
    "main": "index.js",
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "format": "prettier credentials nodes --write",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "npm run build"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "credentials": [
            "dist/credentials/QingflowOaApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/QingflowOa/QingflowOa.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "*",
        "@types/node": "^25.6.2",
        "eslint": "9.39.4",
        "prettier": "3.8.3",
        "release-it": "20.0.1",
        "typescript": "5.9.3"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    },
    "dependencies": {
        "glob": "^13.0.6"
    }
}
